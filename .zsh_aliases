alias v='vim'
alias sv='sudo -e'
alias back='cd -'
alias ls='ls -1 --color=auto'
alias cp='cp --preserve'
alias c='clear'
alias grep='grep --color'
alias df='df -h'
alias du='du -h'
#alias tree="find . -print | sed -e 's;[^/]*/;|____;g;s;____|; |;g'"
alias nocomment='grep -Ev '\''^(#|$)'\'''
alias wget='wget -c'
alias devdown='sudo ip link del'
alias numfiles='ls -A1 | wc -l'

#"nuke lamers from orbit", lol
alias banish="varnishncsa -d | grep \/ip | grep -i wget | awk ‘{ print $1 }’ | sort | uniq | tee -a /etc/hosts.deny"

#telnet server that broadcasts Star Wars Episode IV as animated text
alias star-wars='telnet towel.blinkenlights.nl' 

#telnet nethack game
alias nethack-server='telnet nethack.alt.org'

alias flac2ogg='find . -name "*.flac" -print0 | xargs -0 oggenc -q 10'
alias fsize='du -h --max-depth=0'
alias usage="du -h --max-depth=1 | sort -rh"
alias tusage="du -h --max-depth=1 | sort -rh | head -n 20"
alias off="xset dpms force off"
alias img-clean="exiftool -all="
alias lvim="vim -c \"normal '0\""
alias poweroff='sudo shutdown -Ph now'
alias restart='sudo shutdown -r now'
alias recent='ls -toh | head -n 10'
alias lock='i3lock -c 800080'
alias printfind="nmap -oG - -T4 --open -p 515,631,9100"

#pacman/aur aliases
alias pkg-update="sudo pacman -Syu"
alias pkg-uninstall="sudo pacman -Rs"
alias pkg-mirror-update="sudo reflector --verbose --sort rate -l 30 --save /etc/pacman.d/mirrorlist"
alias pkg-info="pacman -Si"
alias pkg-search="pacman -Ss"
alias pkg-orphans="pacman -Qdt"
alias pkg-remove-orphans='sudo pacman -Rs $(pacman -Qtdq)'
alias pkg-install="sudo pacman -S"
alias pkg-files="pacman -Ql"
alias pkg-foreigns="pacman -Qmq"
alias pkg-locals="pacman -Qeq"
alias pkg-officials="comm -23 <(pacman -Qeq|sort) <(pacman -Qmq|sort)"
alias pkg-local-sorted-size="comm -23 <(pacman -Qeq|sort) <(pacman -Qmq|sort)| xargs pkg-size | sort -rn -k 2"    #needs pkg-size script
alias pkg-needs="whoneeds"
alias pkg-new-updates="checkupdates"


#listening ports
alias ports='ss -tulan'

#rip audio cd and encode to ogg
alias ripcd='abcde -o vorbis:"-q 10"'

#some git aliases
alias ga='git add'
alias gp='git push'
alias gl='git log'
alias gs='git status'
alias gd='git diff'
alias gdc='git diff --cached'
alias gm='git commit -m'
alias gma='git commit -am'
alias gb='git branch'
alias gc='git checkout'
alias gra='git remote add'
alias grr='git remote rm'
alias gpu='git pull'
alias gcl='git clone'
