conky.config = {
    out_to_x = false,
    own_window = false,
    background = false,
    cpu_avg_samples = 2,
    net_avg_samples = 2,
    total_run_times = 0,
    short_units = true,
    no_buffers = true,
    out_to_console = true,
    out_to_stderr = false,
    extra_newline = false,
    update_interval = 1.0,
    uppercase = false,
    use_spacer = 'none',
    if_up_strictness = 'address',
}

conky.text = [[
    [
        {"full_text": "${loadavg}",
            "color": "\#FF1493"},
        {"full_text": "/: ${fs_free /}",
            "color": "\#FF3400"},
        {"full_text": "TEMP: $acpitemp C",
            "color": "\#00FF00"},
        {"full_text": "${time %a.%d.%m.%Y  %R}",
            "color": "\#FFFFFF"}
    ],
]];
