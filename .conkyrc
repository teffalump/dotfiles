conky.config = {
    out_to_x = false,
    own_window = false,
    background = false,
    cpu_avg_samples = 2,
    net_avg_samples = 2,
    total_run_times = 0,
    short_units = true,
    no_buffers = true,
    out_to_console = true,
    out_to_stderr = false,
    extra_newline = false,
    update_interval = 1.0,
    uppercase = false,
    use_spacer = 'none',
    if_up_strictness = 'address',
}

conky.text = [[
    [
        {"full_text": "${loadavg}",
            "color": "\#FF1493"},
        {"full_text": "${if_up tun0}VPN: ${addrs tun0}${endif}",
            "color": "\#FF5500"},
        {"full_text": "${if_up enp3s0f1}E: ${upspeedf enp3s0f1}/${downspeedf enp3s0f1} ${addrs enp3s0f1}${endif}",
            "color": "\#FF0000"},
        {"full_text": "${if_up wlp2s0}W: ${upspeedf wlp2s0}/${downspeedf wlp2s0} ${addrs wlp2s0}${endif}",
            "color": "\#FF0000"},
        {"full_text": "/:${fs_free /}",
            "color": "\#FF3400"},
        {"full_text": "${battery_short BAT1} ${battery_time BAT1}",
            "color": "\#AA0093"},
        {"full_text": "${execi 4 ponymix get-volume} vol",
            "color": "\#00FF7F"},
        {"full_text": "${execi 4 light}",
            "color": "\#FFFF00"},
        {"full_text": "TEMP: $acpitemp C",
            "color": "\#00FF00"},
        {"full_text": "${time %a.%d.%m.%Y  %R}",
            "color": "\#FFFFFF"}
    ],
]];
