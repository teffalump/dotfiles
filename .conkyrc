out_to_x no
background no
cpu_avg_samples 2
net_avg_samples 2
no_buffers yes
out_to_console yes
out_to_stderr no
extra_newline no
update_interval 1.0
uppercase no
use_spacer none
top_name_width 8
if_up_strictness address

#using i3bar - so need to ouput in json
TEXT
[
{"full_text": "${loadavg}",
    "color": "\#FF1493"},
{"full_text": "/:${fs_free /} ~:${fs_free /home}",
    "color": "\#FF3400"},
{"full_text": "${execi 7 ponymix get-volume} vol",
    "color": "\#00FF7F"},
{"full_text": "TEMP: $acpitemp C",
    "color": "\#00FF00"},
{"full_text": "${time %a.%d.%m.%Y  %R}",
    "color": "\#FFFFFF"}
],

