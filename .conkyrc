out_to_x no
background no
cpu_avg_samples 2
net_avg_samples 2
no_buffers yes
out_to_console yes
out_to_stderr no
extra_newline no
update_interval 1.0
uppercase no
use_spacer none
top_name_width 8
if_up_strictness address

#using i3bar - so need to ouput in json
TEXT
[
{"full_text": "${top pid 1}:${top name 1} C:${top cpu 1} :::: ${top_mem pid 1}:${top_mem name 1} M:${top_mem mem 1}",
    "color": "\#FF1493"},
{"full_text": "${if_up tun0}VPN${endif}${if_up wlp4s0}/W- U: ${upspeedf wlp4s0} D: ${downspeedf wlp4s0}${else}/E- U: ${upspeedf enp2s0} D: ${downspeedf enp2s0}${endif}",
    "color": "\#00FFFF"},
{"full_text": "/:${fs_free /} ~:${fs_free /home}",
    "color": "\#FF3400"},
{"full_text": "${execi 7 pamixer --get-volume} vol",
    "color": "\#00FF7F"},
{"full_text": "TEMP: $acpitemp C",
    "color": "\#00FF00"},
{"full_text": "RAM: $memperc%",
    "color": "\#4B0082"},
{"full_text": "CPU: $cpu%",
    "color": "\#FF0000"},
{"full_text": "${time %a.%d.%m.%Y  %R}",
    "color": "\#FFFFFF"}
],

