source! ~/.vimperatorrc.local
:js styles.addSheet(false, "mintabwidth", "chrome://*", ".tabbrowser-tab[fadein]:not([pinned]) { min-width: 16px !important; } .scrollbutton-up, .scrollbutton-down { display:none; }");


set pageinfo=gfm
set runtimepath=/home/cz/.vimperator
set maxitems=7
set scrollbars=false
set tabnumbers=true
set titlestring=""
set verbose=4
set focuscontent=true
set complete=tbf
set defsearch=s

" Some javascript commands
" Show passwords in forms -- 0 = alert box, keep masked; 1 = remove mask
map <silent> sp :js showPasswords(0)<CR>
map <silent> sr :js showPasswords(1)<CR>
js << EOF
    showPasswords=function(a) 
    {
        var F,j,f,i;
        var s = new Array();
        F = content.document.forms;
        for (j=0; j<F.length; ++j) 
        { 
            f = F[j];
            for (i=0; i<f.length; ++i) 
            { 
                if (f.elements[i].type.toLowerCase() == "password")
                {
                    if (a)
                    {
                        f.elements[i].type = "text";
                    }
                    else
                    {
                        s.push(f.elements[i].value); 
                    }
                }
            } 
        } 
        if (!a)
        {
            if (s) 
            {
                alert("Passwords in forms on this page:\n\n" + s.join("\n"));
            }
            else 
            {
                alert("There are no passwords in forms on this page.");
            }
        }

    }
EOF

" Pin to pinboard
map <silent> pi :js popup_with_tags()<CR>
js << EOF
    popup_with_tags=function()
    {
q=content.document.location.href;if(document.getSelection){d=document.getSelection();}else{d='';};p=document.title;void(open('https://pinboard.in/add?showtags=yes&url='+encodeURIComponent(q)+'&description='+encodeURIComponent(d)+'&title='+encodeURIComponent(p),'Pinboard','toolbar=no,scrollbars=yes,width=750,height=700'));
}
EOF

" Pin to pinboard 'read later'
map <silent> pl :js read_later()<CR>
js << EOF
    read_later=function()
    {
q=content.document.location.href;p=document.title;void(t=open('https://pinboard.in/add?later=yes&noui=yes&jump=close&url='+encodeURIComponent(q)+'&title='+encodeURIComponent(p),'Pinboard','toolbar=no,width=100,height=100'));t.blur();
    }

" Change youtube to specific part
js <<EOF
time_changeYoutube= function () { 
    if (location.hostname=='www.youtube.com') { 
        var time_m=prompt('How many minutes?') || 0;
        var time_s=prompt('How many seconds?') || 0;
        var hash='#t='+time_m+'m'+time_s+'s';
        if (location.hash==null||location.hash=='') { 
            window.location.href=window.location.href.replace(/$/, hash); 
        } 
        else { 
            window.location.href=window.location.pathname+window.location.search+hash; 
        } 
        }
    }
EOF

map <silent> <C-m> :js util.copyToClipboard('<a href="'+content.document.location+'">'+content.document.title+'</a>', true);<CR>
map <silent> <C-y> :js util.copyToClipboard(content.document.title,true);<CR>
noremap gb gT
