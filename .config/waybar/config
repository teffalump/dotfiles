{
    "layer": "top",
    "position": "bottom",
    "modules-left": ["sway/workspaces", "sway/mode"],
    "modules-center": ["sway/window"],
    "modules-right": ["cpu", "disk", "temperature", "clock", "tray"],
    "sway/window": {
        "max-length": 50
    },
    "cpu": {
        "format": "{load}"
    },
    "battery": {
        "format": "{capacity}% {icon}",
        "format-icons": ["", "", "", "", ""]
    },
    "clock": {
        "format-alt": "{:%a, %d. %b  %H:%M}"
    },
    "disk": {
        "format": "{free}",
        "path": "/"
    }
}
